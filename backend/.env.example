# ── Environment ──────────────────────────────────────────────────────
# Set to "production" on your server. Controls error verbosity, logging, etc.
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────
MONGO_URI=your_mongodb_connection_string

# ── Server ───────────────────────────────────────────────────────────
PORT=5000

# ── Auth ─────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key
# Use a strong password (12+ characters, mixed case, numbers, symbols)
ADMIN_PASSWORD=your_admin_password

# ── Email (Gmail) ────────────────────────────────────────────────────
# Use an "App Password", not your account password
MAIL_USER=youraddress@gmail.com
MAIL_PASS=your_app_password_here
# Recipient for the Package Cost emails (defaults to MAIL_USER if omitted)
MAIL_PACKAGE_TO=destination@example.com

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS in production.
# Example: https://aspirationasia.com,https://www.aspirationasia.com
# Leave empty in development to allow any origin.
CORS_ORIGIN=

# ── Uploads ──────────────────────────────────────────────────────────
# Where uploaded payment slips are stored on disk. Defaults to ./uploads if unset.
# In production, point this OUTSIDE the repo so deploys can never wipe it.
# Example: /var/data/aspiration-uploads
UPLOAD_DIR=
